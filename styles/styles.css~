*{
    box-sizing: border-box;
}
body{
    background: #140E34;
    margin: 0;
    padding: 0;
    color: #F5F5F5;
    font-family: Varela Round;
    font-weight: 400;
    font-size: 25px;
    position: relative;
}
header{
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 5px;
    background: black;
    font-size: 20px;
    position: sticky;
    z-index: 1000;
    top: 0;
}
nav a {
    text-decoration: none; /* Removes underline */
    color: inherit; /* Uses the default text color of the parent element */
    margin: 0 15px;
}

nav a:visited {
    color: inherit; /* Ensures visited links don't change color */
}

nav a:hover {
    color: #00fbff; /* Optional: Change color on hover */
}

#section-home{
    top: 0;
    bottom: 0;
    left: 0;
    margin: auto;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    height: 100vh;
    padding-top: 80px;
    padding-left: 20px;
    position: relative;
}
h3{
    font-size: 50px;
}

#section-home-photo{
    display: flex;
    align-items: flex-end;
    right: 0;
    top: 0;
    position: absolute;
    padding-top: 50px;
    padding-right: 20px;
}
#circle{
    display: flex;
    align-items: flex-end;
    position: absolute;
    right: 0;
    bottom: 0;
    left: 0;
    margin: auto;
    width: 400px;
    height: 400px;
    border-radius: 100%;
    background: #342a61;
    z-index: -1;
    opacity: 0.5;
    padding-top: 20px;
}


