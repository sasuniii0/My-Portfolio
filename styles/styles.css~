*{
    box-sizing: border-box;
}
body{
    background: #140E34;
    margin: 0;
    padding: 0;
    color: #F5F5F5;
    font-family: Varela Round;
    font-weight: 400;
    font-size: 20px;
    position: relative;
}
header{
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 5px;
    background: black;
    font-size: 20px;
    position: sticky;
    z-index: 1000;
    top: 0;
}

.nav_item{
    text-decoration: none; /* Removes underline */
    color: inherit; /* Uses the default text color of the parent element */
    margin: 0 15px;
}

nav a:visited {
    color: inherit; /* Ensures visited links don't change color */
}

nav a:hover {
    color: #00fbff; /* Optional: Change color on hover */
}

#section-home{
    top: 0;
    bottom: 0;
    left: 0;
    margin: auto;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    height: 70vh;
    padding-top: 80px;
    padding-left: 20px;
    position: relative;
}
h3{
    font-size: 35px;
}

#section-home-photo{
    display: flex;
    align-items: flex-end;
    right: 0;
    top: 0;
    left: 0;
    padding-top: 10px;
    margin: auto;
    position: absolute;
}
#home-photo{
    display: flex;
    width: 770px;
    top: 0;
    right: 0;
    left: 730px;
    margin-top: 0;
    position: absolute;
    margin-bottom: 100px;
}
#circle{
    display: flex;
    align-items: flex-end;
    padding-right: 10px;
    padding-top: 10px;
    width: 450px;
    height: 450px;
    border-radius: 100%;
    background: #342a61;
    z-index: -1;
    opacity: 0.5;
    position: absolute;
    right: 0;
    left: 0;
    top: 0;
    bottom: 0;
    margin-top: 180px;
    margin-left: 930px;
}
img{
    color: white;
}
#download{
    position: absolute;
    right: 0;
    left: 0;
    top: 0;
    bottom: 0;
    margin-top: 450px;
    margin-left: 900px;
    width: 100px;
    height: 100px;
    background-color: white;
    padding: 15px 32px;
    text-align: center;
    display: inline-block;
    font-size: 16px;
    cursor: pointer;
    z-index: -1;
    border-radius: 50%;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
    transition: transform 0.2s ease, box-shadow 0.2s ease;

}
#download:hover{
    background: #00fbff;
}
button{
    border-radius: 50px;
    padding: 15px 40px;
}
.button:hover{
    background-color: #00fbff;
    transform: scale(1.1);
    box-shadow: 0 6px 15px rgba(0, 0, 0, 0.3);
    border-radius: 50px;
}
.social{
    width: 90px;
    display: block;
    position: absolute;
    right: 0;
    top: 300px;
    padding-right: 180px;
}
.sec{
    height: 70px;
    padding-left: 20px;
}
main{
    padding: 5px 5px 5px 5px;
}
#fullPg{
    padding: 0;
}
#section-aboutMe{
    position: relative;
    padding: 25px;
}
#circleAboutMe{
    padding: 20px;
    position: absolute;
    width: 420px;
    height: 420px;
    border-radius: 50%;
    background: #342a61;
    z-index: -1;
}
#circleAboutMe img{
    display:flex;
    align-items: flex-start;
    position: absolute;
    top: 0;
    left: 0;
    padding: 10px;
}
.line{
    position: absolute;
    display: flex;
    background: white;
    height: 2px;
}
#aboutMeLine{
    position: relative;
}
#aboutMeBox{
    position: absolute;
    right: 50px;
    top: 0;
}
#aboutMeBox {
    background: linear-gradient(to bottom, #2b1055, #3a0d62);
    padding: 20px;
    border-radius: 15px;
    width: 800px;
    color: white;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.3);
}

#aboutMeBox p {
    display: flex;
    margin: 8px 0;
}
.right {
    text-align: right;
}
.left{
    text-align: left;
}
#desc{
    text-align: right;
    position: absolute;
    top: 280px;
    right: 0;
    padding-right: 10px;
    padding-left: 450px;
}